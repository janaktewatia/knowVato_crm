{
  "compilerOptions": {
    "target": "ES2020", "module": "CommonJS", "moduleResolution": "node",
    "outDir": "./dist", "rootDir": "./src", "strict": true,
    "esModuleInterop": true, "skipLibCheck": true, "resolveJsonModule": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*.ts"]
}
