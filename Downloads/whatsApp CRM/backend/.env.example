# ── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ── Database ───────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/whatsapp_crm

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=7d

# ── Redis / queue (optional; campaign sender falls back to inline if absent) ──
REDIS_URL=redis://127.0.0.1:6379
USE_QUEUE=false

# ── WhatsApp Cloud API (fill from Meta to enable real sending) ──
# Until these are set with a verified WABA, sends run in SIMULATION mode.
WHATSAPP_MODE=simulation            # simulation | live
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=my-webhook-verify-token
WHATSAPP_APP_SECRET=
