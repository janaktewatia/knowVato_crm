{
  "name": "whatsapp-crm-backend",
  "version": "1.0.0",
  "description": "WhatsApp Business Suite + Admissions CRM — backend API (Node, TypeScript, Express, MongoDB)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "ts-node-dev --transpile-only src/seed/seed.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/jobs/worker.ts",
    "lint": "echo \"(add eslint as needed)\""
  },
  "keywords": ["whatsapp", "crm", "express", "mongodb", "typescript"],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
